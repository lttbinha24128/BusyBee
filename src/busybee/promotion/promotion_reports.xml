<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="25"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="busybee.promotion.PromotionReportController"
      styleClass="promotion-page">

    <!-- ================= TITLE ================= -->

    <Label text="Promotion Reports"
           styleClass="promotion-title"/>


    <!-- ================= FILTER ================= -->

    <HBox spacing="10"
          alignment="CENTER_LEFT">

        <Label text="Time Range:"/>

        <ComboBox fx:id="cbTimeRange"
                  prefWidth="160"/>

    </HBox>


    <!-- ================= SUMMARY CARDS ================= -->

    <HBox spacing="20">

        <VBox styleClass="report-card"
              prefWidth="220"
              alignment="CENTER_LEFT"
              spacing="6">

            <Label text="Total Promo Usage"/>

            <Label fx:id="lblUsage"
                   styleClass="report-number"/>

        </VBox>

        <VBox styleClass="report-card"
              prefWidth="220"
              alignment="CENTER_LEFT"
              spacing="6">

            <Label text="Revenue via Promo"/>

            <Label fx:id="lblRevenue"
                   styleClass="report-number"/>

        </VBox>

        <VBox styleClass="report-card"
              prefWidth="220"
              alignment="CENTER_LEFT"
              spacing="6">

            <Label text="Total Discount"/>

            <Label fx:id="lblDiscount"
                   styleClass="report-number"/>

        </VBox>

    </HBox>


    <!-- ================= BAR CHART ================= -->

    <VBox spacing="10">

        <Label text="Promotion Usage"
               styleClass="section-title"/>

        <BarChart fx:id="usageChart"
                  prefHeight="320"
                  legendVisible="false"
                  styleClass="promotion-chart">

            <xAxis>
                <CategoryAxis label="Promotion"/>
            </xAxis>

            <yAxis>
                <NumberAxis label="Usage Count"/>
            </yAxis>

        </BarChart>

    </VBox>


    <!-- ================= TOP PROMOTIONS TABLE ================= -->

    <VBox spacing="10"
          VBox.vgrow="ALWAYS">

        <Label text="Top Performing Promotions"
               styleClass="section-title"/>

  <TableView fx:id="topPromoTable"
           styleClass="report-table"
           VBox.vgrow="ALWAYS">

    <columnResizePolicy>
        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
    </columnResizePolicy>

    <columns>

        <TableColumn fx:id="colPromo" text="Promotion"/>
        <TableColumn fx:id="colUsage" text="Usage"/>
        <TableColumn fx:id="colRevenue" text="Revenue"/>
        <TableColumn fx:id="colStatus" text="Status"/>

    </columns>

</TableView>

    </VBox>

</VBox>