<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="busybee.billing.controller.BillingListController"
      style="-fx-padding:20;">

    <!-- TITLE -->
    <Label text="💳 Billing Management"
           styleClass="billing-title"/>

    <!-- TOOLBAR -->
    <HBox spacing="10"
          alignment="CENTER_LEFT"
          styleClass="billing-toolbar">

        <!-- SEARCH -->
        <TextField fx:id="txtSearch"
                   promptText="Search billing..."
                   prefWidth="250"
                   styleClass="billing-search"/>

        <!-- STATUS FILTER -->
        <ComboBox fx:id="cbStatus"
                  promptText="Status"
                  prefWidth="140"
                  styleClass="billing-filter"/>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- CREATE PAYMENT -->
        <Button fx:id="btnCreatePayment"
                text="➕ Create Payment"
                styleClass="btn-create"/>

        <!-- CREATE INVOICE -->
        <Button fx:id="btnCreateInvoice"
                text="📄 Create Invoice"
                styleClass="btn-create"/>

    </HBox>

    <!-- TAB PANE -->
    <TabPane fx:id="billingTabPane"
             tabClosingPolicy="UNAVAILABLE"
             VBox.vgrow="ALWAYS">

        <!-- PAYMENTS TAB -->
        <Tab text="Payments">

            <VBox spacing="10" style="-fx-padding:10;">

                <TableView fx:id="paymentsTable"
                           VBox.vgrow="ALWAYS"
                           styleClass="billing-table">

                    <columns>

                        <TableColumn fx:id="colPaymentId"
                                     text="Payment ID"
                                     prefWidth="100"/>

                        <TableColumn fx:id="colRequestId"
                                     text="Request ID"
                                     prefWidth="100"/>

                        <TableColumn fx:id="colAmount"
                                     text="Amount"
                                     prefWidth="120"/>

                        <TableColumn fx:id="colMethod"
                                     text="Method"
                                     prefWidth="120"/>

                        <TableColumn fx:id="colPaidAt"
                                     text="Paid At"
                                     prefWidth="150"/>

                        <TableColumn fx:id="colPaymentStatus"
                                     text="Status"
                                     prefWidth="100"/>

                        <TableColumn fx:id="colReceivedBy"
                                     text="Received By"
                                     prefWidth="150"/>

                        <TableColumn fx:id="colPaymentAction"
                                     text="Action"
                                     prefWidth="120"/>

                    </columns>

                </TableView>

            </VBox>

        </Tab>

        <!-- INVOICES TAB -->
        <Tab text="Invoices">

            <VBox spacing="10" style="-fx-padding:10;">

                <TableView fx:id="invoicesTable"
                           VBox.vgrow="ALWAYS"
                           styleClass="billing-table">

                    <columns>

                        <TableColumn fx:id="colInvoiceId"
                                     text="Invoice ID"
                                     prefWidth="100"/>

                        <TableColumn fx:id="colInvoiceRequestId"
                                     text="Request ID"
                                     prefWidth="100"/>

                        <TableColumn fx:id="colInvoiceNo"
                                     text="Invoice No"
                                     prefWidth="150"/>

                        <TableColumn fx:id="colIssuedAt"
                                     text="Issued At"
                                     prefWidth="150"/>

                        <TableColumn fx:id="colTotalAmount"
                                     text="Total Amount"
                                     prefWidth="120"/>

                        <TableColumn fx:id="colInvoiceStatus"
                                     text="Status"
                                     prefWidth="100"/>

                        <TableColumn fx:id="colGeneratedBy"
                                     text="Generated By"
                                     prefWidth="150"/>

                        <TableColumn fx:id="colInvoiceAction"
                                     text="Action"
                                     prefWidth="120"/>

                    </columns>

                </TableView>

            </VBox>

        </Tab>

    </TabPane>

</VBox>