<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="busybee.billing.controller.BillingCreateController"
      style="-fx-padding:20;">

    <!-- TITLE -->
    <Label fx:id="lblTitle"
           text="Create Payment"
           styleClass="billing-title"/>

    <!-- FORM FIELDS -->
    <GridPane hgap="15"
              vgap="15"
              styleClass="billing-form">

        <!-- PAYMENT FIELDS -->
        <VBox fx:id="paymentFields"
              spacing="15"
              GridPane.columnIndex="0"
              GridPane.rowIndex="0"
              GridPane.columnSpan="2">

            <!-- REQUEST ID -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Request ID:" prefWidth="120"/>
                <TextField fx:id="txtRequestId" promptText="Enter request ID" prefWidth="200"/>
                <Button fx:id="btnSearchRequest" text="🔍 Search" styleClass="btn-secondary"/>
            </HBox>

            <!-- AMOUNT -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Amount ($):" prefWidth="120"/>
                <TextField fx:id="txtAmount" promptText="0.00" prefWidth="200"/>
            </HBox>

            <!-- PAYMENT METHOD -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Payment Method:" prefWidth="120"/>
                <ComboBox fx:id="cbMethod" promptText="Select method" prefWidth="200">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="CASH"/>
                            <String fx:value="CARD"/>
                            <String fx:value="BANK"/>
                            <String fx:value="CHECK"/>
                        </FXCollections>
                    </items>
                </ComboBox>
            </HBox>

            <!-- RECEIVED BY -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Received By:" prefWidth="120"/>
                <TextField fx:id="txtReceivedBy" promptText="Employee name" prefWidth="200"/>
            </HBox>

        </VBox>

        <!-- INVOICE FIELDS -->
        <VBox fx:id="invoiceFields"
              spacing="15"
              GridPane.columnIndex="0"
              GridPane.rowIndex="0"
              GridPane.columnSpan="2"
              visible="false">

            <!-- REQUEST ID -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Request ID:" prefWidth="120"/>
                <TextField fx:id="txtInvoiceRequestId" promptText="Enter request ID" prefWidth="200"/>
                <Button fx:id="btnSearchInvoiceRequest" text="🔍 Search" styleClass="btn-secondary"/>
            </HBox>

            <!-- INVOICE NO -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Invoice No:" prefWidth="120"/>
                <TextField fx:id="txtInvoiceNo" promptText="Auto-generated" prefWidth="200" editable="false"/>
            </HBox>

            <!-- TOTAL AMOUNT -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Total Amount ($):" prefWidth="120"/>
                <TextField fx:id="txtTotalAmount" promptText="0.00" prefWidth="200"/>
            </HBox>

            <!-- GENERATED BY -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Generated By:" prefWidth="120"/>
                <TextField fx:id="txtGeneratedBy" promptText="Employee name" prefWidth="200"/>
            </HBox>

        </VBox>

    </GridPane>

    <!-- BUTTONS -->
    <HBox spacing="15"
          alignment="CENTER_RIGHT"
          styleClass="billing-buttons">

        <Button fx:id="btnSave"
                text="💾 Save"
                styleClass="btn-primary"
                prefWidth="100"/>

        <Button fx:id="btnCancel"
                text="❌ Cancel"
                styleClass="btn-secondary"
                prefWidth="100"/>

    </HBox>

</VBox>