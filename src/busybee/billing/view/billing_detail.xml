<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<VBox spacing="20"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="busybee.billing.controller.BillingDetailController">

    <stylesheets>
        <URL value="@/busybee/style/busybee.css"/>
        <URL value="@/busybee/style/billing.css"/>
    </stylesheets>
     

    <!-- TITLE -->
    <Label fx:id="lblTitle"
           text="Payment Details"
           styleClass="billing-title"/>

    <!-- DETAILS GRID -->
    <GridPane hgap="20"
              vgap="15"
              styleClass="billing-details">

        <!-- PAYMENT DETAILS -->
        <VBox fx:id="paymentDetails"
              spacing="15"
              GridPane.columnIndex="0"
              GridPane.rowIndex="0">

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Payment ID:" styleClass="detail-label"/>
                <Label fx:id="lblPaymentId" styleClass="detail-value"/>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Request ID:" styleClass="detail-label"/>
                <Label fx:id="lblRequestId" styleClass="detail-value"/>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Amount:" styleClass="detail-label"/>
                <Label fx:id="lblAmount" styleClass="detail-value"/>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Method:" styleClass="detail-label"/>
                <Label fx:id="lblMethod" styleClass="detail-value"/>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Paid At:" styleClass="detail-label"/>
                <Label fx:id="lblPaidAt" styleClass="detail-value"/>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Status:" styleClass="detail-label"/>
                <Label fx:id="lblPaymentStatus" styleClass="detail-value status-badge"/>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Received By:" styleClass="detail-label"/>
                <Label fx:id="lblReceivedBy" styleClass="detail-value"/>
            </HBox>

        </VBox>

        <!-- INVOICE DETAILS -->
        <VBox fx:id="invoiceDetails"
              spacing="15"
              GridPane.columnIndex="0"
              GridPane.rowIndex="0"
              visible="false">

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Invoice ID:" styleClass="detail-label"/>
                <Label fx:id="lblInvoiceId" styleClass="detail-value"/>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Request ID:" styleClass="detail-label"/>
                <Label fx:id="lblInvoiceRequestId" styleClass="detail-value"/>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Invoice No:" styleClass="detail-label"/>
                <Label fx:id="lblInvoiceNo" styleClass="detail-value"/>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Issued At:" styleClass="detail-label"/>
                <Label fx:id="lblIssuedAt" styleClass="detail-value"/>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Total Amount:" styleClass="detail-label"/>
                <Label fx:id="lblTotalAmount" styleClass="detail-value"/>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Status:" styleClass="detail-label"/>
                <Label fx:id="lblInvoiceStatus" styleClass="detail-value status-badge"/>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Generated By:" styleClass="detail-label"/>
                <Label fx:id="lblGeneratedBy" styleClass="detail-value"/>
            </HBox>

        </VBox>

    </GridPane>

    <!-- BUTTONS -->
    <HBox spacing="15"
          alignment="CENTER_RIGHT"
          styleClass="billing-buttons">

        <Button fx:id="btnEdit"
                text="✏ Edit"
                styleClass="btn-primary"
                prefWidth="100"/>

        <Button fx:id="btnClose"
                text="❌ Close"
                styleClass="btn-secondary"
                prefWidth="100"/>

    </HBox>

</VBox>