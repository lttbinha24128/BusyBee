<?xml version="1.0" encoding="UTF-8"?> 
<?import javafx.scene.control.*?> 
<?import javafx.scene.layout.*?>
<VBox fx:controller="busybee.layout.sidebar.SidebarWarehouseController"
      xmlns:fx="http://javafx.com/fxml"
      spacing="8" styleClass="sidebar" style="-fx-padding:10;">

    <!-- Dashboard -->
    <Button text="Dashboard" onAction="#showDashboard" styleClass="sidebar-button"/>

    <!-- Tools & Supplies -->
    <TitledPane text="Tools and Supplies" expanded="false">
        <VBox spacing="6" style="-fx-padding:5;">
            <Button text="Item List" onAction="#showItemList" styleClass="sidebar-subbutton"/>
            <Button text="Add/Update Item" onAction="#showUpdateItem" styleClass="sidebar-subbutton"/>
        </VBox>
    </TitledPane>

    <!-- Stock Management -->
    <TitledPane text="Stock Management" expanded="false">
        <VBox spacing="6" style="-fx-padding:5;">
            <Button text="Stock In" onAction="#showStockIn" styleClass="sidebar-subbutton"/>
            <Button text="Stock Out" onAction="#showStockOut" styleClass="sidebar-subbutton"/>
            <Button text="Inventory Check" onAction="#showInventoryCheck" styleClass="sidebar-subbutton"/>
        </VBox>
    </TitledPane>

    <!-- Damage & Expiry -->
    <TitledPane text="Damage and Expiry" expanded="false">
        <VBox spacing="6" style="-fx-padding:5;">
            <Button text="Report Damage" onAction="#showReportDamage" styleClass="sidebar-subbutton"/>
            <Button text="Report Expiry" onAction="#showReportExpiry" styleClass="sidebar-subbutton"/>
            <Button text="Damage/Expiry List" onAction="#showDamageExpiryList" styleClass="sidebar-subbutton"/>
            <Button text="Action Taken" onAction="#showDamageAction" styleClass="sidebar-subbutton"/>
        </VBox>
    </TitledPane>

    <!-- Distribution -->
    <TitledPane text="Distribution" expanded="false">
        <VBox spacing="6" style="-fx-padding:5;">
            <Button text="Request Distribution" onAction="#showDistributionRequest" styleClass="sidebar-subbutton"/>
            <Button text="Pending Distribution" onAction="#showPendingDistribution" styleClass="sidebar-subbutton"/>
            <Button text="Completed Distribution" onAction="#showCompletedDistribution" styleClass="sidebar-subbutton"/>
            <Button text="Return Handling" onAction="#showReturnHandling" styleClass="sidebar-subbutton"/>
        </VBox>
    </TitledPane>

    <!-- Reports -->
    <TitledPane text="Reports" expanded="false">
        <VBox spacing="6" style="-fx-padding:5;">
            <Button text="Stock Report" onAction="#showStockReport" styleClass="sidebar-subbutton"/>
            <Button text="Usage Report" onAction="#showUsageReport" styleClass="sidebar-subbutton"/>
            <Button text="Distribution Report" onAction="#showDistributionReport" styleClass="sidebar-subbutton"/>
            <Button text="Damage/Expiry Report" onAction="#showDamageExpiryReport" styleClass="sidebar-subbutton"/>
        </VBox>
    </TitledPane>

</VBox>
