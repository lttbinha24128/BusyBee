<?xml version="1.0" encoding="UTF-8"?> 
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox fx:controller="busybee.layout.sidebar.SidebarOfficeController"
      xmlns:fx="http://javafx.com/fxml"
      spacing="8" styleClass="sidebar" style="-fx-padding:10;">

    <!-- Dashboard -->
    <Button text="Dashboard" onAction="#showDashboard" styleClass="sidebar-button"/>

    <!-- Service Requests -->
    <TitledPane text="Service Requests" expanded="false">
        <VBox spacing="6" style="-fx-padding:5;">
            <Button text="New Requests" onAction="#showNewRequests" styleClass="sidebar-subbutton"/>
            <Button text="Processing" onAction="#showProcessingRequests" styleClass="sidebar-subbutton"/>
            <Button text="Completed" onAction="#showCompletedRequests" styleClass="sidebar-subbutton"/>
        </VBox>
    </TitledPane>

    <!-- Helper Management -->
    <TitledPane text="Helper Management" expanded="false">
        <VBox spacing="6" style="-fx-padding:5;">
            <Button text="Helper List" onAction="#showHelperList" styleClass="sidebar-subbutton"/>
            <Button text="Availability" onAction="#showHelperAvailability" styleClass="sidebar-subbutton"/>
            <Button text="Performance" onAction="#showHelperPerformance" styleClass="sidebar-subbutton"/>
        </VBox>
    </TitledPane>

    <!-- Assignment -->
    <TitledPane text="Assignment" expanded="false">
        <VBox spacing="6" style="-fx-padding:5;">
            <Button text="Assignment Requests" onAction="#showAssignmentRequests" styleClass="sidebar-subbutton"/>
            <Button text="Assignment Status" onAction="#showAssignmentStatus" styleClass="sidebar-subbutton"/>
            <Button text="Reassignment" onAction="#showReassignment" styleClass="sidebar-subbutton"/>
        </VBox>
    </TitledPane>

    <!-- Inventory Request -->
    <Button text="Inventory Request" onAction="#showInventoryRequest" styleClass="sidebar-button"/>

</VBox>
