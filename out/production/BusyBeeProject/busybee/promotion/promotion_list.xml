<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="busybee.promotion.PromotionListController"
      style="-fx-padding:20;">

    <!-- PAGE TITLE -->
    <Label text="🎉 Promotion Management"
           styleClass="promotion-title"/>

    <!-- TOOLBAR -->
    <HBox spacing="10"
          alignment="CENTER_LEFT"
          styleClass="promotion-toolbar">

        <!-- SEARCH -->
        <TextField fx:id="txtSearch"
                   promptText="Search promotion..."
                   prefWidth="250"/>

        <!-- STATUS FILTER -->
        <ComboBox fx:id="cbStatus"
                  promptText="Status"
                  prefWidth="140"/>

        <!-- SERVICE FILTER (THÊM MỚI) -->
        <ComboBox fx:id="cbService"
                  promptText="Service"
                  prefWidth="160"/>

        <!-- PUSH BUTTON RIGHT -->
        <Region HBox.hgrow="ALWAYS"/>

        <!-- CREATE BUTTON -->
        <Button fx:id="btnCreate"
                text="➕ Create Promotion"
                styleClass="btn-create"/>

    </HBox>

    <!-- TABLE -->
    <TableView fx:id="promotionTable"
               styleClass="promotion-table"
               VBox.vgrow="ALWAYS">

        <columns>

            <TableColumn fx:id="colName"
                         text="Name"
                         prefWidth="180"/>

            <TableColumn fx:id="colService"
                         text="Service"
                         prefWidth="140"/>

            <TableColumn fx:id="colDiscountType"
                         text="Type"
                         prefWidth="100"/>

            <TableColumn fx:id="colDiscountValue"
                         text="Value"
                         prefWidth="100"/>

            <TableColumn fx:id="colStartDate"
                         text="Start Date"
                         prefWidth="120"/>

            <TableColumn fx:id="colEndDate"
                         text="End Date"
                         prefWidth="120"/>

            <TableColumn fx:id="colStatus"
                         text="Status"
                         prefWidth="100"/>

            <TableColumn fx:id="colAction"
                         text="Action"
                         prefWidth="180"/>

        </columns>

    </TableView>

</VBox>